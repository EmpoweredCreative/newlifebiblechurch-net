APP_NAME="New Life Bible Church"
APP_ENV=local
# Required. Generate: php artisan key:generate --show
# On Forge: set in Environment (never leave empty) or run php artisan key:generate on the server, then php artisan config:clear
APP_KEY=
APP_DEBUG=true
# Production: use your real URL (https://...) so signed URLs and assets resolve correctly.
APP_URL=http://localhost

# Set to 1 if `npm run dev` fails with "should not run the Vite HMR server in CI"
LARAVEL_BYPASS_ENV_CHECK=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# SendGrid — same pattern as typical Laravel sites: API key + SMTP (Laravel Mail).
# Contact form, registration approval, “account approved”, and password reset all use Mail::.
# ---------------------------------------------------------------------------
# 1. API key: https://app.sendgrid.com/settings/api_keys (Mail Send permission).
# 2. Verify MAIL_FROM_ADDRESS as a Single Sender (or domain auth) in SendGrid.
# 3. Set SENDGRID_API_KEY below. You may leave MAIL_MAILER=log — the app switches to SendGrid
#    SMTP automatically when the key is present (except in PHPUnit). Or set explicitly:
#    MAIL_MAILER=sendgrid
# 4. After deploy: php artisan config:clear
SENDGRID_API_KEY=

MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Default mailer when SENDGRID_API_KEY is empty (local dev). With the key set, production
# normally uses the `sendgrid` mailer (see config/mail.php + AppServiceProvider).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# --- Website contact form (Connect page) — where visitor messages are sent ---
CONTACT_FORM_TO="contact@newlifebiblechurch.net"
# Legacy alias (optional): if set and CONTACT_FORM_TO is empty, contact mail uses this instead.
# MAIL_CONTACT_TO=

# --- Account registration — approval requests (separate from contact form) ---
REGISTRATION_APPROVER_EMAIL="danny@empoweredcreative.co"

# Contact form anti-spam (optional; defaults are sensible)
# CONTACT_MIN_FILL_MS=3000
# CONTACT_MAX_FORM_AGE_MS=3600000
# CONTACT_MAX_URLS=6

# REGISTRATION_APPROVE_LINK_TTL_MINUTES=20160
# REGISTRATION_MIN_FILL_MS=3000
# REGISTRATION_MAX_FORM_AGE_MS=3600000
# REGISTRATION_CLOCK_SKEW_MS=120000

# Optional overrides for the built-in `sendgrid` mailer (defaults match SendGrid docs):
# SENDGRID_SMTP_HOST=smtp.sendgrid.net
# SENDGRID_SMTP_PORT=587
# SENDGRID_SMTP_USERNAME=apikey

# Termageddon embeds (full iframe src URLs for Privacy Policy and Terms pages)
TERMAGEDDON_PRIVACY_EMBED_URL=
TERMAGEDDON_TERMS_EMBED_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

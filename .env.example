APP_NAME="New Life Bible Church"
APP_ENV=local
# Required. Generate: php artisan key:generate --show
# On Forge: set in Environment (never leave empty) or run php artisan key:generate on the server, then php artisan config:clear
APP_KEY=
APP_DEBUG=true
# Production: use your real URL (https://...) so signed URLs and assets resolve correctly.
APP_URL=http://localhost

# Set to 1 if `npm run dev` fails with "should not run the Vite HMR server in CI"
LARAVEL_BYPASS_ENV_CHECK=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Forge/production: use MySQL or Postgres — not sqlite under `database/database.sqlite` in a release (file missing per deploy).
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=forge
# DB_USERNAME=forge
# DB_PASSWORD=
# Local MySQL example:
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# SendGrid — shared config at config('services.sendgrid'); delivery via Laravel Mail + SendGrid Web API (HTTPS :443).
# Default mailer `sendgrid` uses the API (works on Forge; outbound SMTP :587 to smtp.sendgrid.net is often blocked).
#    Requires `symfony/http-client` in composer.json (not pulled in automatically by symfony/sendgrid-mailer alone).
# Optional escape hatch: MAIL_MAILER=sendgrid-smtp if your host allows SMTP.
# Primary flows: (1) contact form → staff inbox, (2) new registration → approver (PendingRegistrationMail).
# With SENDGRID_API_KEY set, the default mailer switches from log/array to sendgrid unless MAIL_MAILER is set otherwise.
# ---------------------------------------------------------------------------
# 1. API key: https://app.sendgrid.com/settings/api_keys (Mail Send permission). Store only in SENDGRID_API_KEY.
# 2. Verify the sender: Single Sender or Domain Authentication for the address you use as From
#    (SENDGRID_FROM_EMAIL and/or MAIL_FROM_ADDRESS). Unverified senders are rejected or dropped.
# 3. Set SENDGRID_API_KEY below. You may leave MAIL_MAILER=log — the app switches to the sendgrid mailer
#    when the key is present (except in PHPUnit). Or set MAIL_MAILER=sendgrid explicitly.
# 4. After deploy or env changes with config caching: php artisan config:clear
#    Contact + pending-registration + approval emails send during the HTTP request (not the queue), so no queue worker is required for them.
SENDGRID_API_KEY=

# Visible From for outbound mail (used by contact + pending registration Mailables via config('mail.from')).
# SENDGRID_FROM_* are mirrored in config('services.sendgrid'); MAIL_FROM_* still wins when set (see AppServiceProvider).
# SENDGRID_FROM_EMAIL=noreply@newlifebiblechurch.net
# SENDGRID_FROM_NAME="${APP_NAME}"

# Staff inbox for the public contact form only (internal recipient). Same env as config('services.sendgrid.to_email').
# Optional display name for that recipient (ContactController uses Address when set).
# SENDGRID_TO_EMAIL=contact@newlifebiblechurch.net
# SENDGRID_TO_NAME="Church office"

# Outbound SMTP socket timeout (seconds), for MAIL_MAILER=sendgrid-smtp or generic smtp only.
# MAIL_SMTP_TIMEOUT=15

# Standard Laravel “from” (takes precedence over SENDGRID_FROM_* when set).
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Default mailer when SENDGRID_API_KEY is empty (local dev). With the key set, production
# normally uses the `sendgrid` mailer (see config/mail.php + AppServiceProvider).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# --- Website contact form (Connect page) — where visitor messages are sent ---
CONTACT_FORM_TO="contact@newlifebiblechurch.net"
# If CONTACT_FORM_TO is empty: MAIL_CONTACT_TO, then SENDGRID_TO_EMAIL, then default domain inbox.
# MAIL_CONTACT_TO=

# --- Account registration — approval requests (separate from contact form) ---
REGISTRATION_APPROVER_EMAIL="danny@empoweredcreative.co"

# Contact form anti-spam (optional; defaults are sensible)
# CONTACT_MIN_FILL_MS=3000
# CONTACT_MAX_FORM_AGE_MS=3600000
# CONTACT_MAX_URLS=6

# REGISTRATION_APPROVE_LINK_TTL_MINUTES=20160
# REGISTRATION_MIN_FILL_MS=2000
# REGISTRATION_MAX_FORM_AGE_MS=3600000
# REGISTRATION_CLOCK_SKEW_MS=600000

# Optional overrides for MAIL_MAILER=sendgrid-smtp only:
# SENDGRID_SMTP_HOST=smtp.sendgrid.net
# SENDGRID_SMTP_PORT=587
# SENDGRID_SMTP_USERNAME=apikey

# Privacy Policy and Terms & Conditions are Blade views with Termageddon embeds:
# resources/views/legal/privacy.blade.php and resources/views/legal/terms.blade.php

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
